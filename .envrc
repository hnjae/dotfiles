# shellcheck shell=sh

prek install
prek install -t pre-merge-commit
prek install -t pre-push

# Skip worktree for fcitx5 profile to avoid local changes being committed
git update-index --skip-worktree "profiles/40-linux-desktop/xdg-config/fcitx5/profile" 2>/dev/null
git update-index --skip-worktree "profiles/40-kde/xdg-config/plasmaparc" 2>/dev/null
