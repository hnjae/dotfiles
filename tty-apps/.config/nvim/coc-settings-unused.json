    "pyright.disableDiagnostics": false,
    // default: false
    "pyright.organizeimports.provider": "isort",
    // default: pyright
    "pyright.completion.snippetSupport": false,
    // completion은 jedi 사용
    "python.analysis.autoImportCompletions": true,
    // default: true
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": ["-q", "--line-length", "79", "-"],
    "python.linting.enabled": true,
    // default: true
    "python.linting.pylintEnabled": false,
    "jedi.diagnostics.enable": true,
    "diagnostic-languageserver.filetypes": {
        // "python": ["pylint", "flake8"]
        "python": ["pylint"]
    },
    "diagnostic-languageserver.formatFiletypes": {
        "python": [
            "black",
            "isort",
            "docformatter"
        ]
    },
    "diagnostic-languageserver.linters": {
        "pylint": {
            "sourceName": "pylint",
            "command": "pylint",
            "args": [
                "--output-format",
                "text",
                "--score",
                "no",
                "--msg-template",
                "'{line}:{column}:{category}:{msg} ({msg_id}:{symbol})'",
                "--disable=W0212,W0511,W0611,W0612,W0613,C0301,C0116",
                // W0212: protected-access
                // W0511: TODO Fixme
                // W0611: unused-import
                // W0612: unused-variable
                // W0613: Unused-argument
                // C0301: Line-too-long
                // C0116: missing-function-docstring
                // C0103: invalid-name (function?)
                "%file"
            ],
            "formatPattern": [
                "^(\\d+?):(\\d+?):([a-z]+?):(.*)$",
                {
                    "line": 1,
                    "column": 2,
                    "security": 3,
                    "message": 4
                }
            ],
            "rootPatterns": [
                ".git",
                "pyproject.toml",
                "setup.py"
            ],
            "securities": {
                "informational": "hint",
                "refactor": "info",
                "convention": "info",
                "warning": "warning",
                "error": "error",
                "fatal": "error"
            },
            "offsetColumn": 1,
            "formatLines": 1
        },
        "flake8": {
            "sourceName": "flake8",
            "command": "flake8",
            "debounce": 200,
            "rootPatterns": [
                ".git",
                "pyproject.toml",
                "setup.py"
            ],
            "args": [
                // "--ignore=E402,C901,W503,W504,E116,E702,C0103,C0114,C0115,C0116,C0103,C0301,W0613,W0102,R0903,R0902,R0914,R0915,R0205,W0703,W0702,W0603,F401",
                "--ignore=F401,E301,E302,E303,E501",
                // F401: unused <>: 다른 곳 pylint에서 다뤄지므로 제거
                // E301: expected 1 blank line, found 0
                // E303: too many blank lines: Formatter 가 알아서 정리해주므로 제거
                // E501: line too long
                "--format=%(row)d,%(col)d,%(code).1s,%(code)s: %(text)s",
                "-"
            ],
            "offsetLine": 0,
            "offsetColumn": 0,
            "formatLines": 1,
            "formatPattern": [
                "(\\d+),(\\d+),([A-Z]),(.*)(\\r|\\n)*$",
                {
                    "line": 1,
                    "column": 2,
                    "security": 3,
                    "message": 4
                }
            ],
            "securities": {
                "W": "info",
                "E": "warning",
                "F": "info",
                "C": "info",
                "N": "hint"
            }
        }
    },
    "diagnostic-languageserver.formatters": {
        "black": {
            "command": "black",
            "args": ["-q", "--line-length", "79", "-"]
        },
        "isort": {
            "command": "isort",
            "args": ["-q", "-"]
        },
        "docformatter": {
            "command": "docformatter",
            "args": ["-"]
        }
    },
