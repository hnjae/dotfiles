! config for low-level X applications
! xorg-xrdb should be installed

! Xft Settings
! https://ricostacruz.com/til/fractional-scaling-on-xorg-linux
Xft.dpi: 192
Xft.autohint: 0
Xft.lcdfilter:  lcddefault
Xft.hintstyle:  hintfull
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb
Xcursor.size: 48

! UXTerm Settings
UXTerm*allowBoldFonts: false
UXTerm*termName: xterm-256color
XTerm.termName: xterm-256color

! vscode dark
*.foreground: #d4d4d4
*.background: #1e1e1e
*.cursorColor: #d4d4d4
*.color0: #000000
*.color1: #f44747
*.color2: #608b4e
*.color3: #dcdcaa
*.color4: #569cd6
*.color5: #c678dd
*.color6: #56b6c2
*.color7: #d4d4d4
*.color8: #808080
*.color9: #f44747
*.color10: #608b4e
*.color11: #dcdcaa
*.color12: #569cd6
*.color13: #c678dd
*.color14: #56b6c2
*.color15: #d4d4d4

xterm*decTerminalID    :   vt340
