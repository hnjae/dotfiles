% appman, AppImage

# Update appman itself
appman sync

# query package information
appman about <package>

# download install script
appman download <package>

# download package not in repository
appman extra <user>/<project> <APPNAME>

# Update all
appman update

# List installed and available packages
appman list

# List installed and available appimages
appman list --appimages

# List installed packages
appman files
