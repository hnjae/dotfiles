% agent, codex,

# run codex with devenv
devenv shell -- codex -a on-request --sandbox workspace-write --no-alt-screen

# run codex with devenv with danger-full-access
devenv shell -- codex -a on-request --sandbox danger-full-access --no-alt-screen

# run codex with nix develop with danger-full-access
nix develop '.#default' --command codex -a on-request --sandbox danger-full-access --no-alt-screen

# run codex with specific nix develop with danger-full-access
nix develop ".#${PWD##*/}" --command codex -a on-request --sandbox danger-full-access --no-alt-screen

# run codex with direnv (sandboxed)
direnv exec . codex -a on-request --sandbox workspace-write --no-alt-screen

# run codex with direnv
direnv exec . codex -a on-request --sandbox danger-full-access --no-alt-screen

# run codex without sandbox
codex --sandbox danger-full-access -a on-request --no-alt-screen

# run codex with sandbox
codex --sandbox workspace-write -a on-request --no-alt-screen

# run codex with devenv with with READONLY
codex -a never --sandbox read-only --no-alt-screen --no-alt-screen

