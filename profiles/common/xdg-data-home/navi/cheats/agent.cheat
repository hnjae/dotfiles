% agent, codex,

# run codex with devenv
devenv shell codex -a on-request  --sandbox workspace-write

# run codex with direnv
direnv exec . codex -a on-request  --sandbox workspace-write

# run codex without sandbox
codex --sandbox danger-full-access -a untrusted

# run codex with sandbox
codex --sandbox workspace-write -a on-request
