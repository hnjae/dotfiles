{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5"
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.5"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low"
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "lsp": {
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ],
      "priority": 10
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    },
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md"
      ],
      "priority": 10
    },
    "docker-ls": {
      "command": [
        "docker-language-server",
        "start"
      ],
      "extensions": [
        "Containerfile",
        "Dockerfile"
      ]
    }
  }
}
