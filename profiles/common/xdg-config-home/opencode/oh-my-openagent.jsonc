// https://github.com/code-yeongyu/oh-my-openagent/blob/v3.17.0/docs/reference/configuration.md
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    /*
      Core Agents:
        - Sisyphus: The default orchestrator. Plans, delegates, and executes complex tasks using specialized subagents with aggressive parallel execution.
        - Hephaestus: The Legitimate Craftsman. Autonomous deep worker inspired by AmpCode's deep mode.
        - Oracle:  Architecture consultation: GPT-5.4 or Claude Opus
        - librarian: Multi-repo analysis, documentation lookup, OSS implementation examples.
        - explore: Fast codebase exploration and contextual grep.
        - multimodal-looker: Visual content specialist. Analyzes PDFs, images, diagrams to extract information.
    */

    // Main orchestrator: Claude Opus or Kimi K2.5 work best
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "opencode/kimi-k2.5" },
        { "model": "opencode/glm-5" },
        { "model": "opencode/big-pickle" }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "opencode/gemini-3.1-pro", "variant": "medium" }
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        { "model": "opencode/gemini-3.1-pro", "variant": "high" }
      ]
    },

    // Research agents: cheap fast models are fine
    "librarian": {
      "model": "openai/gpt-5.4-nano",
      "fallback_models": [{ "model": "opencode/minimax-m2.7-highspeed" }]
    },

    "explore": {
      "model": "openai/gpt-5.4-nano",
      "fallback_models": [{ "model": "opencode/minimax-m2.7" }]
    },

    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [{ "model": "opencode-go/kimi-k2.5" }]
    },

    /*
      Planning Agents:
        - Prometheus: Strategic planner with interview mode.
        - Momus: Plan reviewer
        - Metis: Plan consultant
    */

    // Prometheus inherits sisyphus model; just add prompt guidance
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "opencode/glm-5" },
        { "model": "opencode/gemini-3.1-pro" }
      ]
    },

    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        { "model": "opencode/glm-5" },
        { "model": "opencode/gemini-3.1-pro" }
      ]
    },

    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "opencode/gemini-3.1-pro", "variant": "high" },
        { "model": "opencode/glm-5" }
      ]
    },

    /*
      Orchestration Agents:
        - Atlas: Todo-list orchestrator.
        - sisyphus-junior: Category-spawned executor.
    */
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "opencode/kimi-k2.5" },
        { "model": "opencode/minimax-m2.7" }
      ]
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "opencode/gpt-5.4",
          "variant": "medium"
        },
        {
          "model": "opencode/big-pickle"
        }
      ]
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "opencode/gpt-5.4",
          "variant": "xhigh"
        },
        {
          "model": "opencode/gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },

    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        { "model": "opencode/gemini-3.1-pro", "variant": "high" }
      ]
    },

    // Creative/unconventional approaches
    "artistry": {
      "model": "openai/gpt-5.4",
      "fallback_models": [
        { "model": "opencode/gemini-3.1-pro", "variant": "high" }
      ]
    },

    // Trivial tasks, typo fixes, single-file changes
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [{ "model": "opencode/gemini-3-flash" }]
    },

    // General tasks, low effort
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "opencode/kimi-k2.5" },
        { "model": "opencode/gemini-3-flash" },
        { "model": "opencode/minimax-m2.7" }
      ]
    },

    // General tasks, high effort
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        { "model": "opencode/glm-5" },
        { "model": "opencode/kimi-k2.5" },
        { "model": "opencode/gemini-3.1-pro", "variant": "high" }
      ]
    },

    // Documentation, prose, technical writing
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        { "model": "opencode/gemini-3-flash" },
        { "model": "opencode/kimi-k2.5" },
        { "model": "opencode/minimax-m2.7" }
      ]
    },

    // visual-engineering - Gemini dominates visual tasks
    "visual-engineering": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high",
      "fallback_models": [
        { "model": "openai/gpt-5.4", "variant": "xhigh" },
        { "model": "opencode/glm-5" }
      ]
    },

    // Custom category for git operations
    "git": {
      "model": "opencode/gpt-5.4-nano"
    }
  },
  "tmux": { "enabled": false },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  },
  "lsp": {
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"],
      "priority": 10
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    }
  }
}
