{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "librarian": {
      "model": "openai/gpt-5.3-codex-spark",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.3-codex-spark",
      "variant": "high"
    }
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5.3-codex-spark",
      "variant": "high"
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": { "commit_footer": true, "include_co_authored_by": true },
  "lsp": {
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"],
      "priority": 10
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    },
    "qmlls": {
      "command": ["qmlls", "--no-cmake-calls"],
      "extensions": [".qml"],
      "priority": 10
    },
    "docker-ls": {
      "command": ["docker-language-server", "start"],
      "extensions": ["Containerfile", "Dockerfile"]
    }
  }
}
