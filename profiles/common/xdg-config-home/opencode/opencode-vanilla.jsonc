{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "build": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    }
  },
  "permission": {
    "read": {
      "/nix/store/**": "allow"
    },
    "glob": {
      "/nix/store/**": "allow"
    },
    "grep": {
      "/nix/store/**": "allow"
    },
    "list": {
      "/nix/store/**": "allow"
    },
    "external_directory": {
      "/nix/store/**": "allow"
    },
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "bash": {
      "npm *": "deny",
      "sudo *": "deny",
      "nix-env *": "deny"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    },
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md"]
    },
    "docker-ls": {
      "command": ["docker-language-server", "start"],
      "extensions": ["Containerfile", "Dockerfile"]
    }
  }
}
