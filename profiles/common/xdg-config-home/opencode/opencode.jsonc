{
  "$schema": "https://opencode.ai/config.json",
  // "model": "openai/gpt-5.5",
  // "small_model": "openai/gpt-5.4-mini",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "build": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    }
  },
  "permission": {
    "read": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow"
    },
    "glob": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow"
    },
    "grep": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow"
    },
    "list": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow"
    },
    "external_directory": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow"
    },
    "bash": {
      "npm *": "deny",
      "sudo *": "deny",
      "nix-env *": "deny"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    },
    "qmlls": {
      "command": ["qmlls", "--no-cmake-calls"],
      "extensions": [".qml"]
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    },
    "rumdl": {
      "command": ["rumdl", "server"],
      "extensions": [".md"]
    },
    "docker-ls": {
      "command": ["docker-language-server", "start"],
      "extensions": ["Containerfile", "Dockerfile"]
    }
  }
}
