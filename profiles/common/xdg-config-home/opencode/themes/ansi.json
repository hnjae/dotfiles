    "darkBg0": 0,
    "darkBg1": 8,
    "darkBg2": 8,
    "darkBg3": 7,
    "darkFg0": 15,
    "darkFg1": 7,
    "darkGray": 8,
    "darkRed": 1,
    "darkGreen": 2,
    "darkYellow": 3,
    "darkBlue": 4,
    "darkPurple": 5,
    "darkAqua": 6,
    "darkOrange": 3,
    "darkRedBright": 9,
