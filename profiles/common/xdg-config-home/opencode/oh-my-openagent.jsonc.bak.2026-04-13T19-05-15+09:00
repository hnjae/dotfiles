{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Main orchestrator: handles delegation and drives tasks to completion
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "ultrawork": { "model": "openai/gpt-5.4", "variant": "xhigh" }
    },

    // Deep autonomous worker: end-to-end implementation (default 5.4 medium)
    "hephaestus": { "model": "openai/gpt-5.4" },

    // Strategic planner: interview mode before execution
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },

    // Architecture consultant: complex design and debugging (default 5.4 high)
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },

    // Documentation and code search (default: mini-max-m2.7)
    "librarian": { "model": "openai/gpt-5.4-mini", "variant": "xhigh" },

    // Rapid codebase navigation (default grok-code-fast-1)
    "explore": { "model": "openai/gpt-5.4-mini-fast" },

    // Visual tasks: UI/UX, images, diagrams (default: gemini pro high)
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },

    // Plan consultant: reviews and improves plans
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },

    // Critic and reviewer
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },

    // Continuation and long-running task handler (default sonnet 4.6)
    "atlas": { "model": "openai/gpt-5.4-mini" },

    // Lightweight task executor for simple jobs (default sonnet 4.6)
    "sisyphus-junior": { "model": "openai/gpt-5.4-mini" }
  },
  "categories": {
    // Visual architecture
    "visual-engineering": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Strategic reasoning
    "ultrabrain": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Deep research and analysis (default: 5.4 medium)
    "deep": { "model": "openai/gpt-5.4" },

    // Trivial changes: fastest possible
    "quick": { "model": "openai/gpt-5.4-mini-fast" },

    // : good quality, fast (default: sonnet 4.6)
    "unspecified-low": { "model": "openai/gpt-5.4-mini" },

    // High-effort planning tasks: maximum reasoning
    "unspecified-high": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Documentation from plans (default: gemini-3-flash)
    "writing": { "model": "openai/gpt-5.4-mini-fast", "variant": "xhigh" },

    // Creative approaches to problems (default: gemini-3-pro high)
    "artistry": { "model": "openai/gpt-5.4", "variant": "xhigh" }
  },
  "tmux": { "enabled": true },
  "lsp": {
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"],
      "priority": 10
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    }
  }
}
