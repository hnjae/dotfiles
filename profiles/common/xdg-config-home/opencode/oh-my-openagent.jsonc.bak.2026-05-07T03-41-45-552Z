{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // Main orchestrator: handles delegation and drives tasks to completion
    "sisyphus": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Deep autonomous worker: end-to-end implementation (default 5.4 medium)
    "hephaestus": { "model": "openai/gpt-5.4" },

    // Strategic planner: interview mode before execution
    "prometheus": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Architecture consultant: complex design and debugging (default 5.4 high)
    "oracle": { "model": "openai/gpt-5.4", "variant": "high" },

    // Documentation and code search (default: mini-max-m2.7)
    "librarian": { "model": "openai/gpt-5.4-mini", "variant": "xhigh" },

    // Rapid codebase navigation: prioritize portability and low-latency official model ids
    "explore": { "model": "openai/gpt-5.4-mini", "variant": "low" },

    // Visual tasks: UI/UX, images, diagrams (default: gemini pro high)
    "multimodal-looker": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Plan consultant: reviews and improves plans
    "metis": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Critic and reviewer
    "momus": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Continuation and long-running task handler: benefit from 5.4's larger context window
    "atlas": { "model": "openai/gpt-5.4" },

    // Lightweight task executor for simple jobs (default sonnet 4.6)
    "sisyphus-junior": { "model": "openai/gpt-5.4-mini" }
  },
  "categories": {
    // Visual architecture
    "visual-engineering": { "model": "openai/gpt-5.4", "variant": "high" },

    // Strategic reasoning
    "ultrabrain": { "model": "openai/gpt-5.4", "variant": "xhigh" },

    // Deep research and analysis (default: 5.4 medium)
    "deep": { "model": "openai/gpt-5.4" },

    // Trivial changes: favor official model ids and minimal reasoning overhead
    "quick": { "model": "openai/gpt-5.4-mini", "variant": "low" },

    // Good quality while keeping token usage under control
    "unspecified-low": { "model": "openai/gpt-5.4-mini", "variant": "low" },

    // High-effort planning tasks: strong reasoning without always paying xhigh cost
    "unspecified-high": { "model": "openai/gpt-5.4", "variant": "high" },

    // Documentation from plans: keep it fast and coherent without overreasoning
    "writing": { "model": "openai/gpt-5.4-mini", "variant": "low" },

    // Creative approaches to problems
    "artistry": { "model": "openai/gpt-5.4", "variant": "high" }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "lsp": {
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"],
      "priority": 10
    },
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "disabled": true
    },
    "marksman": {
      "command": ["marksman", "server"],
      "extensions": [".md"],
      "priority": 10
    },
    "docker-ls": {
      "command": ["docker-language-server", "start"],
      "extensions": ["Containerfile", "Dockerfile"]
    }
  }
}
