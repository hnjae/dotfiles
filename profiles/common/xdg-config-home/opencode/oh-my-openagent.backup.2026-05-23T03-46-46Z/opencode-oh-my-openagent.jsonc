{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "permission": {
    "read": {
      "/nix/**": "allow",
      "/etc/**": "allow",
      "/usr/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow",
      "/home/hnjae/.local/share/pnpm/**": "allow",
      "/home/hnjae/.local/share/nvim/**": "allow",
      "/home/hnjae/.local/state/nix/**": "allow",
      "/home/hnjae/.nix-profile/**": "allow"
    },
    "glob": {
      "/nix/**": "allow",
      "/etc/**": "allow",
      "/usr/share/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow",
      "/home/hnjae/.local/share/pnpm/**": "allow",
      "/home/hnjae/.local/share/nvim/**": "allow",
      "/home/hnjae/.local/state/nix/**": "allow",
      "/home/hnjae/.nix-profile/**": "allow",
      "/home/hnjae/.cache/pnpm/**": "allow"
    },
    "grep": {
      "/nix/**": "allow",
      "/etc/**": "allow",
      "/usr/share/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow",
      "/home/hnjae/.local/share/pnpm/**": "allow",
      "/home/hnjae/.local/share/nvim/**": "allow",
      "/home/hnjae/.local/state/nix/**": "allow",
      "/home/hnjae/.nix-profile/**": "allow",
      "/home/hnjae/.cache/pnpm/**": "allow"
    },
    "list": {
      "/nix/**": "allow",
      "/etc/**": "allow",
      "/usr/share/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow",
      "/home/hnjae/.local/share/pnpm/**": "allow",
      "/home/hnjae/.local/share/nvim/**": "allow",
      "/home/hnjae/.local/state/nix/**": "allow",
      "/home/hnjae/.nix-profile/**": "allow",
      "/home/hnjae/.cache/pnpm/**": "allow"
    },
    "external_directory": {
      "/nix/**": "allow",
      "/etc/**": "allow",
      "/usr/share/**": "allow",
      "/tmp/**": "allow",
      "/home/hnjae/.local/share/cargo/**": "allow",
      "/home/hnjae/.local/share/pnpm/**": "allow",
      "/home/hnjae/.local/share/nvim/**": "allow",
      "/home/hnjae/.local/state/nix/**": "allow",
      "/home/hnjae/.nix-profile/**": "allow",
      "/home/hnjae/.cache/pnpm/**": "allow"
    },
    "bash": {
      "npm *": "deny",
      "sudo *": "deny",
      "nix-env *": "deny"
    }
  }
}
