# NOTE:
# zmodule 은 built-in module 과 이름이 겹치면 안된다! <2025-06-01>
# `my-` prefix 는 namespace 충돌을 피하기 위한 것.

# This is not sourced during shell startup, and it's only used to configure the
# zimfw plugin manager.

###############################################################################
# Modules
###############################################################################

zmodule direnv

# 단순 환경변수 설정 또는 alias 설정만 있는 모듈들
zmodule "$ZDOTDIR/modules/bat"
zmodule "$ZDOTDIR/modules/cheat"
zmodule "$ZDOTDIR/modules/eza"
zmodule "$ZDOTDIR/modules/flatpak"
zmodule "$ZDOTDIR/modules/home"
zmodule "$ZDOTDIR/modules/jq"
zmodule "$ZDOTDIR/modules/mani"
zmodule "$ZDOTDIR/modules/nix"
zmodule "$ZDOTDIR/modules/podman"
zmodule "$ZDOTDIR/modules/pueue"
zmodule "$ZDOTDIR/modules/rsync"
zmodule "$ZDOTDIR/modules/systemd"
zmodule "$ZDOTDIR/modules/tmux"
zmodule "$ZDOTDIR/modules/zimfw"
zmodule "$ZDOTDIR/modules/yazi"

# 복잡한 모듈
zmodule environment
# zmodule input
zmodule "$ZDOTDIR/modules/termtitle" # loads vcs_info, zsh-hook 있음
zmodule "$ZDOTDIR/modules/navi"
zmodule "MichaelAquilina/zsh-you-should-use"
# zmodule olets/zsh-abbr --source zsh-abbr.plugin.zsh --use git  # it includes submodules # THIS IS FREAKING SLOW (2025-07-07)

zmodule "$ZDOTDIR/modules/git" # forgit 보다 먼저 로드해야 한다.
# NOTE: 26.04.0 부터 `forgit add` 가 고장났음. <2026-04-14>
zmodule wfxr/forgit --tag 26.01.0 --source forgit.plugin.zsh

# 기타
zmodule "$ZDOTDIR/modules/utilities"

zmodule jeffreytse/zsh-vi-mode
zmodule "$ZDOTDIR/modules/fzf"

###############################################################################
# Prompt
###############################################################################

# zmodule sindresorhus/pure --source async.zsh --source pure.zsh # 내부에서 git 호출
# zmodule romkatv/powerlevel10k --use degit
# zmodule "$ZDOTDIR/my-omp"
zmodule "$ZDOTDIR/modules/starship"

###############################################################################
# Completion
###############################################################################

# Additional completion definitions for Zsh.
zmodule zsh-users/zsh-completions --fpath src

# Enables and configures smart and extensive tab completion.
# completion must be sourced after all modules that add completion definitions.
# zmodule completion # init compinit

zmodule "$ZDOTDIR/modules/compinit"
zmodule Aloxaf/fzf-tab --source fzf-tab.plugin.zsh # source after compinit

###############################################################################
# Modules that must be initialized after compinit
###############################################################################

# > For completions to work, the above line must be added after compinit is called. You may have to rebuild your completions cache by running rm ~/.zcompdump*; compinit.
zmodule "$ZDOTDIR/modules/zoxide"


###############################################################################
# Modules that must be initialized last
###############################################################################

# Fish-like syntax highlighting for Zsh.
# zsh-users/zsh-syntax-highlighting must be sourced after completion
zmodule zsh-users/zsh-syntax-highlighting

# Fish-like history search (up arrow) for Zsh.
# must be sourced after zsh-users/zsh-syntax-highlighting
# zmodule zsh-users/zsh-history-substring-search # use fzf's ctrl-r instead

# Fish-like autosuggestions for Zsh.
zmodule zsh-users/zsh-autosuggestions

##########################################################
# vi:ft=zsh
