# vi:ft=zsh

local type="$1"
local scope="$2"
local scope_mode="none"
local format
local prompt
local repo_root
local context_file
local msg_file
local codex_log
local commit_output
local commit_status
local file_path
local diff_bytes
local diff_limit="${GIT_COMMIT_LLM_DIFF_LIMIT:-60000}"
local codex_model="${GIT_COMMIT_LLM_MODEL:-gpt-5.3-codex-spark}"
local codex_effort="${GIT_COMMIT_LLM_REASONING_EFFORT:-high}"
local -a codex_args
local -a staged_files
local -a clean_staged_files
local -a hook_modified_files

if [[ -z "$type" ]]; then
    echo "Usage: git-commit-llm <type|auto> [scope|auto]" >&2
    echo "Example:" >&2
    echo "  git-commit-llm feat" >&2
    echo "  git-commit-llm feat auth" >&2
    echo "  git-commit-llm feat auto" >&2
    echo "  git-commit-llm auto" >&2
    return 1
fi

case "$type" in
auto | feat | fix | refactor | docs | test | style | perf | build | ci | chore) ;;
*)
    echo "Invalid type: $type" >&2
    echo "Allowed types: auto, feat, fix, refactor, docs, test, style, perf, build, ci, chore" >&2
    return 1
    ;;
esac

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Not inside a git repository." >&2
    return 1
}

if git -C "$repo_root" diff --cached --quiet; then
    echo "No staged changes found." >&2
    return 1
fi

staged_files=("${(@f)$(git -C "$repo_root" diff --cached --name-only --)}")
clean_staged_files=()

for file_path in "${staged_files[@]}"; do
    if git -C "$repo_root" diff --quiet -- "$file_path"; then
        clean_staged_files+=("$file_path")
    fi
done

if [[ "$scope" == "auto" ]]; then
    scope_mode="auto"
elif [[ "$type" == "auto" && -z "$scope" ]]; then
    scope_mode="auto"
elif [[ -n "$scope" ]]; then
    scope_mode="fixed"
fi

if [[ "$type" == "auto" ]]; then
    if [[ "$scope_mode" == "fixed" ]]; then
        format="<type>(${scope}): subject"
    else
        format="<type>[(scope)]: subject"
    fi
elif [[ "$scope_mode" == "fixed" ]]; then
    format="${type}(${scope}): subject"
elif [[ "$scope_mode" == "auto" ]]; then
    format="${type}[(scope)]: subject"
else
    format="${type}: subject"
fi

context_file="$(mktemp "${TMPDIR:-/tmp}/git-commit-llm-context.XXXXXX")" || return 1
msg_file="$(mktemp "${TMPDIR:-/tmp}/git-commit-llm-message.XXXXXX")" || {
    rm -f "$context_file"
    return 1
}
codex_log="$(mktemp "${TMPDIR:-/tmp}/git-commit-llm-codex.XXXXXX")" || {
    rm -f "$context_file" "$msg_file"
    return 1
}

diff_bytes="$(git -C "$repo_root" diff --cached --no-ext-diff -- | wc -c | tr -d '[:space:]')"

{
    printf 'Repository: %s\n\n' "$repo_root"

    printf 'Staged files (name-status):\n'
    git -C "$repo_root" diff --cached --name-status --

    printf '\nStaged diff stat:\n'
    git -C "$repo_root" diff --cached --stat --summary --

    printf '\nStaged numstat:\n'
    git -C "$repo_root" diff --cached --numstat --

    printf '\nStaged patch'
    if ((diff_bytes > diff_limit)); then
        printf ' (first %s bytes of %s bytes; truncated):\n' "$diff_limit" "$diff_bytes"
        git -C "$repo_root" diff --cached --no-ext-diff -- | head -c "$diff_limit"
        printf '\n'
    else
        printf ':\n'
        git -C "$repo_root" diff --cached --no-ext-diff --
    fi
} >|"$context_file"

prompt="Generate exactly one Conventional Commit message from the staged context in stdin.
Do not run tools or shell commands. Use only the provided staged context.

Format requirements:"

if [[ "$type" == "auto" ]]; then
    prompt="$prompt
- You MUST choose the best Conventional Commit type from this list: feat, fix, refactor, docs, test, style, perf, build, ci, chore"
else
    prompt="$prompt
- You MUST use this exact type: $type"
fi

if [[ "$scope_mode" == "fixed" ]]; then
    prompt="$prompt
- You MUST use this exact scope: $scope
- Structure: \`$format\`"
elif [[ "$scope_mode" == "auto" ]]; then
    prompt="$prompt
- Include a scope only when the staged changes have a clear, specific scope
- Use a concise lowercase scope from the primary package, module, tool, config area, or file area
- Do NOT include a scope when the scope would be broad, ambiguous, or invented
- Structure: \`$format\`"
else
    prompt="$prompt
- Do NOT include a scope
- Structure: \`$format\`"
fi

prompt="$prompt

Subject rules:
- Imperative mood
- Present tense
- Start the description after the colon with lowercase
- <=72 characters
- Describe the primary staged change
- Prefer exact package, library, tool, or file names over broad categories
- If a single dependency or package is added, name it directly
- Focus on WHAT changed, not WHY

Body rules:
- Add a body only if essential context cannot fit in the subject
- If body is needed, keep it concise

Output rules:
- Do NOT add a Codex co-author trailer; these are user-authored changes
- Return only the commit message
- No code fences, no explanation"

codex_args=(
    --model "$codex_model"
    -c "model_reasoning_effort=$codex_effort"
    --disable shell_tool
    --disable codex_git_commit
    --sandbox read-only
    --cd "$repo_root"
    --output-last-message "$msg_file"
    --ephemeral
)

codex exec "${codex_args[@]}" "$prompt" <"$context_file" >|"$codex_log" 2>&1
commit_status=$?

if ((commit_status != 0)); then
    cat "$codex_log" >&2
    rm -f "$context_file" "$msg_file" "$codex_log"
    return "$commit_status"
fi

if [[ ! -s "$msg_file" ]]; then
    echo "Codex returned an empty commit message." >&2
    cat "$codex_log" >&2
    rm -f "$context_file" "$msg_file" "$codex_log"
    return 1
fi

commit_output="$(git -C "$repo_root" commit -F "$msg_file" 2>&1)"
commit_status=$?

if ((commit_status != 0)); then
    hook_modified_files=()

    for file_path in "${clean_staged_files[@]}"; do
        if ! git -C "$repo_root" diff --quiet -- "$file_path"; then
            hook_modified_files+=("$file_path")
        fi
    done

    if ((${#hook_modified_files[@]} > 0)); then
        echo "Staging hook-modified files and retrying commit:" >&2
        printf '  %s\n' "${hook_modified_files[@]}" >&2

        if git -C "$repo_root" add -- "${hook_modified_files[@]}"; then
            commit_output="$(git -C "$repo_root" commit -F "$msg_file" 2>&1)"
            commit_status=$?
        else
            commit_status=$?
        fi
    fi
fi

if [[ -n "$commit_output" ]]; then
    print -r -- "$commit_output"
fi

rm -f "$context_file" "$msg_file" "$codex_log"
return "$commit_status"
