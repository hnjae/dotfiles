# vi:ft=zsh

local type="$1"
local scope="$2"
local format
local prompt
local repo_root
local git_dir
local git_common_dir
local -a codex_args

if [[ -z "$type" ]]; then
    echo "Usage: git-commit-llm <type> [scope]" >&2
    echo "Example:" >&2
    echo "  git-commit-llm feat" >&2
    echo "  git-commit-llm feat auth" >&2
    return 1
fi

case "$type" in
feat | fix | refactor | docs | test | style | perf | build | ci | chore) ;;
*)
    echo "Invalid type: $type"
    echo "Allowed types: feat, fix, refactor, docs, test, style, perf, build, ci, chore"
    return 1
    ;;
esac

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Not inside a git repository."
    return 1
}
git_dir="$(git rev-parse --absolute-git-dir 2>/dev/null)" || return 1
git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || git_common_dir="$git_dir"

if git diff --cached --quiet; then
    echo "No staged changes found."
    return 1
fi

if [[ -n "$scope" ]]; then
    format="${type}(${scope}): subject"
else
    format="${type}: subject"
fi

prompt="Inspect the staged changes and create the git commit yourself.

**Fixed format requirements:**
- You MUST use this exact type: $type"

if [[ -n "$scope" ]]; then
    prompt="$prompt
    - You MUST use this exact scope: $scope
    - Structure: \`$format\`"
else
    prompt="$prompt
    - Do NOT include a scope
    - Structure: \`$format\`"
fi

prompt="$prompt

**Subject rules:**
- Imperative mood
- Present tense
- ≤72 characters
- Describe the primary staged change
- Focus on WHAT changed, not WHY

**Body rules:**
- Add a body only if essential context cannot fit in the subject
- If body is needed, keep it concise

**Commit workflow:**
- Commit the currently staged changes by running git commands yourself.
- Before the first commit attempt, record the staged file list with \`git diff --cached --name-status\` and any pre-existing unstaged files with \`git status --porcelain=v1 --untracked-files=all\`.
- Use Git porcelain commands for repository state; do not inspect \`.git/index\` or \`.git/index.lock\` as a preflight check.
- Missing optional files such as \`.git/index.lock\` are normal; do not run commands that fail when optional lock files are absent.
- Do NOT unstage, restore, reset, or edit files yourself.
- Do NOT stage files except for formatter changes made by git hooks, as described below.
- Do NOT bypass hooks with --no-verify.
- Do NOT add a Codex co-author trailer; these are user-authored changes.
- If commitlint or another commit-message hook rejects the message, read the error, revise the message, and retry.
- If a formatting hook modifies files and the commit fails because those hook changes need staging, stage only hook-modified files that were already in the original staged file list and had no pre-existing unstaged changes, then retry the commit.
- Use path-specific staging such as \`git add -- <paths>\`; never use broad staging like \`git add -A\`.
- If hook changes touch unrelated files, files with pre-existing unstaged changes, or require user action, stop and report the exact reason.
- After success, report the commit hash and commit subject.

Use only the repository at: $repo_root"

codex_args=(
    --model gpt-5.3-codex-spark
    -c model_reasoning_effort=high
    --disable codex_git_commit
    --sandbox workspace-write
    --cd "$repo_root"
    --add-dir "$repo_root"
    --add-dir "$git_dir"
)

if [[ "$git_common_dir" != "$git_dir" ]]; then
    codex_args+=(--add-dir "$git_common_dir")
fi

codex exec "${codex_args[@]}" "$prompt"
