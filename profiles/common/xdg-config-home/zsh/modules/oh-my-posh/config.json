{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "darkGray",
          "foreground_templates": [
            "{{ if .Root }}red{{ end }}",
            "{{ if .SSHSession }}lightYellow{{ end }}"
          ],
          "template": "{{ if .SSHSession }} {{ end }}{{ .UserName }}@{{ .HostName }} ",
          "min_width": 80
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "lightBlue",
          "options": {
            "style": "mixed",
            "display_root": true,
            "max_width": 36,
            "max_depth": 6,
            "mixed_threshold": 12,
            "hide_root_location": true,
            "mapped_locations": {
              "~/projects": " ",
              "~/worktrees": " "
            }
          },
          "template": "{{ .Path }} ",
          "min_width": 70
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "magenta",
          "options": {
            "branch_ahead_icon": "\u2191",
            "branch_behind_icon": "\u2193",
            "branch_gone_icon": "\u2262",
            "branch_icon": "\ue0a0 ",
            "branch_identical_icon": "\u2261",
            "cherry_pick_icon": "\u2713 ",
            "commit_icon": "\u25b7 ",
            "fetch_status": true,
            "merge_icon": "\u25f4 ",
            "no_commits_icon": "[no commits]",
            "rebase_icon": "\u2c62 ",
            "tag_icon": "\u25b6 "
          },
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} \u2502{{ end }}{{ if .Staging.Changed }} {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} {{ .StashCount }}{{ end }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "lightRed",
          "template": "\u001b[1mERROR\u001b[0m "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "shell",
          "style": "plain",
          "foreground": "darkGray",
          "template": "{{ .Name }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "blue",
          "template": "{{ if and .Env.IN_NIX_SHELL (or (not .Env.DEVENV_ROOT) .Env.DEVENV_IN_DIRENV_SHELL .Env.DEVENV_FLAKE_SHELL) }} <darkGray,>|</> 󱄅 {{ .Env.IN_NIX_SHELL }}{{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "yellow",
          "template": "{{ if and .Env.VIRTUAL_ENV (ne .Env.VIRTUAL_ENV \"\") }} <darkGray,>|</>   {{ base .Env.VIRTUAL_ENV }}{{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "cyan",
          "template": "{{ if .Env.DEVENV_ROOT }} <darkGray,>|</>  devenv{{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "green",
          "template": "{{ if .Env.DIRENV_FILE }} <darkGray,>|</>   direnv{{ end }}"
        },
        {
          "type": "root",
          "foreground": "red",
          "style": "plain",
          "template": " <darkGray,>as</> root"
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "darkGray",
          "options": {
            "time_format": "15:04:05"
          },
          "template": " <darkGray,>|</> {{ .CurrentDate | date .Format }}",
          "min_width": 120
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "type": "text",
          "foreground": "foreground",
          "template": "$"
        }
      ],
      "type": "prompt"
    }
  ]
}
