prefix_rule(pattern=["nix-env"], decision="forbidden")
prefix_rule(pattern=["sudo"], decision="forbidden")
prefix_rule(pattern=["npm"], decision="forbidden")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "switch"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["nix", "flake", "show"], decision="allow")
prefix_rule(pattern=["nix", "flake", "check"], decision="allow")
prefix_rule(pattern=["nix", "eval"], decision="allow")
prefix_rule(pattern=["nix", "build"], decision="allow")
prefix_rule(pattern=["nix", "search"], decision="allow")
prefix_rule(pattern=["nix", "profile", "add"], decision="forbidden")
prefix_rule(pattern=["nix", "profile", "install"], decision="forbidden")
prefix_rule(pattern=["virsh", "-c"], decision="allow")
prefix_rule(pattern=["tofu", "providers", "schema"], decision="allow")
prefix_rule(pattern=["tofu", "plan"], decision="allow")
prefix_rule(pattern=["ping"], decision="allow")
prefix_rule(pattern=["nmcli", "connection", "show"], decision="allow")
prefix_rule(pattern=["devenv", "shell", "--", "git", "commit"], decision="allow")
prefix_rule(pattern=["devenv", "shell", "--", "qmlformat"], decision="allow")
prefix_rule(pattern=["devenv", "shell", "--", "clang-format"], decision="allow")
prefix_rule(pattern=["heif-enc", "--list-encoders"], decision="allow")
prefix_rule(pattern=["magick", "-list", "format"], decision="allow")
prefix_rule(pattern=["heif-info", "--help"], decision="allow")
prefix_rule(pattern=["tofu", "fmt"], decision="allow")
prefix_rule(pattern=["devenv", "shell", "--", "tofu"], decision="allow")
prefix_rule(pattern=["cocogitto"], decision="allow")
prefix_rule(pattern=["nix", "run", "nixpkgs#cocogitto"], decision="allow")
prefix_rule(pattern=["pgrep", "-af", "nix.*cocogitto"], decision="allow")
prefix_rule(pattern=["uv", "lock"], decision="allow")
prefix_rule(pattern=["uv", "build"], decision="allow")
prefix_rule(pattern=["nix", "flake", "lock"], decision="allow")
prefix_rule(pattern=["devenv", "shell", "--", "prek"], decision="allow")
