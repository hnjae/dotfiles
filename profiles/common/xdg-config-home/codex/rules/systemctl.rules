prefix_rule(pattern=["systemctl", "hibernate"], decision="forbidden")
prefix_rule(pattern=["systemctl", "sleep"], decision="forbidden")
prefix_rule(pattern=["systemctl", "suspend"], decision="forbidden")
prefix_rule(pattern=["systemctl", "suspend-then-hibernate"], decision="forbidden")
prefix_rule(pattern=["systemctl", "hybrid-sleep"], decision="forbidden")
prefix_rule(pattern=["systemctl", "poweroff"], decision="forbidden")
prefix_rule(pattern=["systemctl", "list-units"], decision="allow")
prefix_rule(pattern=["systemctl", "cat"], decision="allow")
prefix_rule(pattern=["systemctl", "show"], decision="allow")
prefix_rule(pattern=["systemctl", "help"], decision="allow")
prefix_rule(pattern=["systemctl", "is-enabled"], decision="allow")
prefix_rule(pattern=["journalctl"], decision="allow")
