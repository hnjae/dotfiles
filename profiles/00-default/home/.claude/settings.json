{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.ansible.com)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git status:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(curl:*)",
      "Bash(podman build:*)",
      "Bash(nix build:*)",
      "Bash(nix-build:*)",
      "Bash(uv build:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run ty:*)",
      "Bash(ruff:*)",
      "Bash(ty:*)",
      "Bash(cargo build:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(go build:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(ansible-lint:*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(./secrets/**)",
      "Read(**/*.key)",
      "Write(.env*)",
      "Bash(npm:*)",
      "Bash(pip:*)",
      "Bash(pipx:*)"
    ]
  },
  "syntaxHighlightingDisabled": false,
  "model": "opus"
}
