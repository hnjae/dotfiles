{
  "$schema": "https://opencode.ai/config.json",
  // "model": "opencode/gemini-3-flash",
  // "small_model": "openrouter/z-ai/glm-4.7-flash",
  "default_agent": "plan",
  "agent": {
    // "build": {
    // "model": "openrouter/z-ai/glm-4.7-flash"
    // "variant": "xhigh"
    // },
    // "plan": {
    //   "model": "opencode/gpt-5.2",
    //   "variant": "high"
    // }
  },
  "permission": {
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "skill": {
      "git-commit": "allow"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"]
    }
  }
}
