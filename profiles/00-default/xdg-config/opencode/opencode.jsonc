{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "plan",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    }
  },
  "permission": {
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "skill": {
      "git-commit": "allow"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
}
