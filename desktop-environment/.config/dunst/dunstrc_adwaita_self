[global]
	### DISPLAY {{{
	monitor = 0
	# Display notification on focused monitor.  Possible modes are:
	#   mouse: follow mouse pointer
	#   keyboard: follow window with keyboard focus
	#   none: don't follow anything
	#
	# "keyboard" needs a window manager that exports the
	# _NET_ACTIVE_WINDOW property.
	# This should be the case for almost all modern window managers.
	#
	# If this option is set to mouse or keyboard, the monitor option
	# will be ignored.
	follow = mouse

	# geometry format: [{width}][x{height}][+/-{x}[+/-{y}]]
	# geometry = "0x0-30+72"
	geometry = "0x8-50+50"
	# shrink window if it's smaller than the width
	shrink = false
	# height of the entire notification, if smaller, it will be raised.
	notification_height = 0
	#
	separator_height = 2
	# The distance in pixels from the content to the separator/border of
	# the window in the vertical axis
	padding = 8
	horizontal_padding = 8
	text_icon_padding = 16

	sort = true

	progress_bar_max_width = 600
	progress_bar_min_width = 400
	progress_bar_height = 20
	progress_bar_frame_width = 2

    	# indicate_hidden = yes
	### }}}


	word_wrap = true
	# ellipsize = end
	transparency = 0

	# = Theme =
	font = Sans 12
	# Markup is allowed
	markup = full
	# The format of the message.  Possible variables are:
	#   %a  appname
	#   %s  summary
	#   %b  body
	#   %i  iconname (including its path)
	#   %I  iconname (without its path)
	#   %p  progress value if set ([  0%] to [100%]) or nothing
	#   %n  progress value if set without any extra characters
	#   %%  Literal %
	# format = "<b>%s</b>\n%b"
	format = "%s %p\n%b"

	frame_width = 2

	# -----------------------------
	# Define a color for the separator.
	# possible values are:
	#  * auto: dunst tries to find a color fitting to the background;
	#  * foreground: use the same color as the foreground;
	#  * frame: use the same color as the frame;
	#  * anything else will be interpreted as a X color.
	# separator_color = frame
	separator_color = auto

	idle_threshold = 120

	alignment = left
	# vertical_alignment = center
	show_age_threshold = 60

	# word_wrap = true
	icon_position = left
	min_icon_size = 32
	max_icon_size = 140
	# stack_duplicates = false
	icon_path = "/usr/share/icons/la-capitaine/status/scalable-dark/:/usr/share/icons/la-capitaine/devices/scalable-dark/:/usr/share/icons/Adwaita++-Dark/status/symbolic/:/usr/share/icons/Adwaita++-Dark/devices/scalable/:/usr/share/icons/Adwaita/scalable/status/:/usr/share/icons/Adwaita/scalable/devices/"

    	# If set to true, notifications that have been recalled from history will not time out automatically. (default: true)
	sticky_history = false

	corner_radius = 8
	browser = "$BROWSER"

	# Always run rule-defined scripts, even if the notification is suppressed
	# always_run_script = true

	# title = Dunst
	# class = Dunst
	# startup_notification = false

[shortcuts]
	# DEPRECATED - SEE DUNSTCTL (X11 Only)
	# close = ctrl+space
	# close_all = ctrl+shift+space
	history = ctrl+grave
	context = ctrl+shift+period

[urgency_low]
	# IMPORTANT: colors have to be defined in quotation marks.
	# Otherwise the "#" and following would be interpreted as a comment.
	# background = "#353535"
	background = "#353535"
	# foreground = "#eeeeee"
	foreground = "#dddddd"
	frame_color = "#1b1b1b"
	highlight = "#1b6dd0"
	timeout = 4
	# Icon for notifications with low urgency, uncomment to enable
	#icon = /path/to/icon

[urgency_normal]
	# background = "#458588"
	background = "#353535"
	foreground = "#eeeeee"
	frame_color = "#1b1b1b"
	highlight = "#1b6dd0"
	timeout = 4

[urgency_critical]
	background = "#f6f5f4"
	foreground = "#222222"
	frame_color = "#cdc7c2"
	highlight = "#4b92e7"
	timeout = 0

# Every section that isn't one of the above is interpreted as a rules to
# override settings for certain messages.
# Messages can be matched by "appname", "summary", "body", "icon", "category",
# "msg_urgency" and you can override the "timeout", "urgency", "foreground",
# "background", "new_icon" and "format".
# Shell-like globbing will get expanded.
#
# SCRIPTING
# You can specify a script that gets run when the rule matches by
# setting the "script" option.
# The script will be called as follows:
#   script appname summary body icon urgency
# where urgency can be "LOW", "NORMAL" or "CRITICAL".
#
# NOTE: if you don't want a notification to be displayed, set the format
# to "".
# NOTE: It might be helpful to run dunst -print in a terminal in order
# to find fitting options for rules.

# find out desktop_entry by `dunst -print`
[fcitx5]
	summary = "Switch group"
	body = "Switched group to *"
	# desktop_entry="org.fcitx.Fcitx5-migration"
	# msg_urgency = "normal"
	# background = "#ff0000"
	# timeout = 1
	skip_display = true
	# urgency = low

[rfield]
	summary = "(A) Connection Established"
	body = "*\"rfield\"."
	skip_display = true

[xbacklight]
	appname = "xbacklight"
	geometry = "1000x1000-30+72"
	min_icon_size = 48
	max_icon_size = 140


