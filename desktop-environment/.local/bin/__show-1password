#!/usr/bin/env bash

DESKTOP=${XDG_CURRENT_DESKTOP:-$XDG_SESSION_DESKTOP}

# NOTE: electon does not support IME input under wayland yet (~20 version checked)

if ! `pgrep -x "1password" > /dev/null`; then
    # exec 1password --ozone-platform-hint=auto &
    exec 1password &
    exit 0
fi

if [ "$XDG_SESSION_TYPE" = "x11" ]; then
    if `wmctrl -l | grep -E ".*1Password\$" > /dev/null`; then
        if [ "$DESKTOP" = "i3" ]; then
            i3-msg '[instance="1password"]' scratchpad show
        else
            # TODO: Add wmctrl <2022-10-24, Hyunjae Kim>
            # wmctrl -a 1password
            echo "NOT SUPPORTED DE: $DESKTOP"
            notify-send "NOT SUPPORTED DE: $DESKTOP"
        fi
    else
        1password --ozone-platform-hint=auto --toggle
    fi

elif [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    # NOTE: Bashism Code
    if [ "${DESKTOP:0:4}" = "sway" ]; then
        # swaymsg '[app_id="1Password"]' scratchpad show || \
        swaymsg '[class="1Password"]' scratchpad show \
            || 1password --ozone-platform-hint=auto --toggle
    else
        1password --ozone-platform-hint=auto --toggle
    fi
fi
