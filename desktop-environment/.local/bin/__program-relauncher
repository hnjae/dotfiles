#!/usr/bin/env bash

[ "$1" ] || exit 0

type "$1" > /dev/null 2>&1 || exit 1

killall -q "$1"

# NOTE: bash는 "$UID" 변수가 존재하나, dash 는 없음.
# Wait until the processes have been shut down
while pgrep --uid "$UID" -x "$1" > /dev/null; do sleep 0.4; done

sleep 1

# nohup "$@" < /dev/null > /dev/null 2>&1 &
exec "$@" > /dev/null 2>&1 &
