class Monitor:
    def __init__(self, init: Dict):
        self.name: str = init["name"]
        self.active: bool = init["active"]
        self.type: str = init["type"]  # output
        self.make: Optional[str] = init.get("make")
        self.model: Optional[str] = init.get("model")
        self.serial: Optional[str] = init.get("serial")

    def __str__(self):
        return self.name

    def power(self, power: bool):
        if power != self.active:
            if power:
                print(f"Turning On Device - {self}")
                power_str: str = "enable"
            else:
                print(f"Turning Off Device - {self}")
                power_str: str = "disable"
            args = ["swaymsg", self.type, self.name, power_str]
            subprocess.run(args, check=True)

        if power:
            self.set_bg()

        return

    def power_status(self, update: Optional[bool] = False) -> bool:
        if update:
            for mon in self.get_outputs():
                if self == mon:
                    self.active = mon.active
                    return mon.active
            raise Exception("monitor does not exists")
        else:
            return self.active

    def __eq__(self, other):
        return (
            self.name == other.name
            and self.serial == other.serial
            and self.make == other.make
            and self.model == other.model
        )

    def set_bg(self):
        sys.stdout.flush()

        if not BgImages:
            args = ["swaybg", "-o", self.name, "-c", "#111111"]
        else:
            image: str = secrets.choice(BgImages)
            args = [
                "swaybg",
                "--output",
                self.name,
                "--image",
                image,
                "--mode",
                "fill",
            ]
        subprocess.Popen(
            args,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        return

    @staticmethod
    def get_outputs() -> List:
        args: List[str] = ["swaymsg", "--type", "get_outputs", "--raw"]
        proc: CompletedProcess = subprocess.run(
            args,
            capture_output=True,
            check=True,
            encoding=locale.getpreferredencoding(),
        )
        return [Monitor(device) for device in json.loads(proc.stdout)]


def sway_mode() -> None:
    displays_not_home: List[Monitor] = []
    home_display: Optional[Monitor] = None

    # Print
    table_format: str = "| {:<27}| {:<13}| {:14}| {:<9}|"
    print(table_format.format("Maker", "Model", "Serial", "Port"))
    print("-" * 72)
    for device in Monitor.get_outputs():
        # print(device)
        print(
            table_format.format(
                device.make,
                device.model,
                device.serial,
                device.name,
            )
        )
        if device.serial == MY_HOME_MONITOR_SERIAL:
            home_display = device
        else:
            displays_not_home.append(device)
            print("-" * 72)
    # Print END

    if home_display is not None:
        home_display.power(True)
        is_powered_on = home_display.power_status(update=True)
        for display in displays_not_home:
            display.power(not is_powered_on)
    else:
        for display in displays_not_home:
            display.power(True)


def send_noti():
    display_icons: List[str] = [
        "video-display-symbolic",
        # "display",
        # "preferences-desktop-display",
        # "video-display-symbolic",
        # "display-symbolic",
    ]
    noti_args = [
        "notify-send",
        "Display",
        "Adjusted",
        "--urgency=normal",
        f"--icon={','.join(display_icons)}",
        "--category=device",
    ]
    subprocess.run(noti_args, check=True)


def main():

    # if env["XDG_SESSION_TYPE"].lower() != "wayland":
    #     print("Session is not wayland")
    #     return 0

    if "sway" not in {
        os.environ.get("XDG_SESSION_DESKTOP"),
        os.environ.get("XDG_CURRENT_DESKTOP"),
        os.environ.get("DESKTOP_SESSION"),
    }:
        print("XDG_DESKTOP_SESSION is not sway")
        return 0

    subprocess.run(
        ["killall", "swaybg"],
        stdout=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    sway_mode()
    time.sleep(0.2)
    # send_noti()
    return 0


if __name__ == "__main__":
    # time.sleep(1)
    sys.exit(main())
